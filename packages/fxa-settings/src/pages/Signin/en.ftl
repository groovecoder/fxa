# Strings within the <span> elements appear as a subheading.
signin-password-needed-header = Enter your password <span>for your { -product-firefox-account }</span>

# $serviceLogo - an image of the logo of the service which the user is authenticating for.
# For languages structured like English, the phrase can read "to continue to"
signin-subheader-with-logo = Continue to <span>{ $serviceLogo }</span>

# $serviceName - the name of the service which the user authenticating for
# For languages structured like English, the phrase can read "to continue to { $serviceName }"
signin-subheader-without-logo = Continue to { $serviceName }
signin-button = Sign in
signin-header = Sign in
# <br /> is just spacing for visual display. <linkExternal> links to the Terms of Service and also to the Privacy Notice
firefox-and-pocket-tos = By proceeding, you agree to: <br /> { product-pocket }’s <linkExternal>Terms of Service</linkExternal> and <linkExternal>Privacy Notice</linkExternal><br />{ -brand-firefox}’s <linkExternal>Terms of Service</linkExternal> and <linkExternal>Privacy Notice</linkExternal>
# <br /> is just spacing for visual display. <linkExternal> links to the Terms of Service and also to the Privacy Notice
tos-and-privacy = By proceeding, you agree to the <linkExternal>Terms of Service</linkExternal> and <linkExternal>Privacy Notice</linkExternal>
use-a-different-account-link = Use a different account
forgot-password-link = Forgot password?
# A localized descriptive text for screenreaders, identifying the Pocket logo
pocket-logo = { product-pocket } logo
# $serviceName -- the name of the service authenticating the user via firefox accounts. This is a localized descriptive text for screenreaders, identifying the image as a logo for the authenticating service
service-logo = { $serviceName } logo
